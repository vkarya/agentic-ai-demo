##############################################
# Ollama (OpenAI-compatible) LLM configuration
##############################################

# Base URL for Ollama's OpenAI-compatible API
API_BASE=http://localhost:11434/v1

# Model name to use with Ollama
MODEL_NAME=llama3.2

# Pseudo API key for Ollama (not validated by Ollama, but required by client)
API_KEY=ollama

##############################################
# CORS configuration
##############################################

# Comma-separated list of allowed origins for CORS
# Example for local Angular dev server:
# CORS_ORIGINS=http://localhost:4200
